# LLM PROVIDER (one of: openai, ollama)
LLM_PROVIDER=gemini


# --- OpenAI ---
OPENAI_API_KEY=your_openai_api_key_here

GEMINI_API_KEY=your_gemini_api_key_here

# --- Ollama (local) ---
OLLAMA_MODEL=llama3.1

# SMTP for office emails (use an app password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
OFFICE_EMAIL=your_office_email@gmail.com


# Bot settings
SITE_BASE=https://www.krpower.in
COMPANY_NAME=K.R. Power Supports Pvt Ltd
DEFAULT_LOCALE=en

# Backend URL for Streamlit app
# For local development: http://127.0.0.1:8000
# For production: https://ai.krpower.in (or your production backend URL)
BACKEND_URL=http://127.0.0.1:8000

TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
OFFICE_WHATSAPP_TO=whatsapp:+919994460329
